{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "assets/scripts/core/**/*.ts",
    "assets/scripts/domain/**/*.ts",
    "assets/scripts/infrastructure/memory/**/*.ts",
    "assets/scripts/infrastructure/system/**/*.ts",
    "assets/content/**/*.json",
    "tests/**/*.ts"
  ]
}
